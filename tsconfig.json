{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@financialadvisor/shared": ["packages/shared/src"],
      "@financialadvisor/financial-tools": ["packages/financial-tools/src"],
      "@financialadvisor/ai-integration": ["packages/ai-integration/src"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/financial-tools" },
    { "path": "./packages/ai-integration" },
    { "path": "./packages/mcp-server" },
    { "path": "./packages/vscode-extension" }
  ]
}