{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "outDir": "out/test",
    "rootDir": "test",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "types": ["node", "mocha"],
    "noEmit": false
  },
  "include": [
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}