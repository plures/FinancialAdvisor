{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "check-coverage": true,
  "lines": 50,
  "functions": 50,
  "branches": 40,
  "statements": 50,
  "include": [
    "src/shared/financial-utils.ts"
  ],
  "exclude": [
    "src/extension.ts",
    "src/extension/**/*.ts",
    "src/mcp-server/**/*.ts",
    "src/shared/types.ts",
    "test/**/*",
    "coverage/**/*",
    "**/*.d.ts"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "report-dir": "./coverage",
  "cache": true,
  "instrument": true,
  "sourceMap": true
}