{
  "all": false,
  "check-coverage": false,
  "lines": 50,
  "functions": 50,
  "branches": 40,
  "statements": 50,
  "include": ["out/test/src/shared/financial-utils.js"],
  "exclude": [
    "out/test/src/extension.js",
    "out/test/src/extension/**/*.js",
    "out/test/src/mcp-server/**/*.js",
    "out/test/src/shared/types.js",
    "out/test/test/**/*",
    "out/test/packages/**/*",
    "coverage/**/*",
    "**/*.d.ts",
    "**/*.test.js",
    "**/node_modules/**"
  ],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "report-dir": "./coverage",
  "cache": false,
  "instrument": true,
  "sourceMap": false
}
