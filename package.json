{

  "name": "financial-advisor",

  "displayName": "Financial Advisor",

  "description": "Personal AI Financial Advisor - VSCode Extension with MCP Server",

  "version": "0.1.0",

  "publisher": "plures",

  "engines": {

    "vscode": "^1.104.0",

    "node": ">=22.0.0"

  },

  "categories": [

    "Other"

  ],

  "keywords": [

    "ai",

    "finance",

    "advisor",

    "mcp",

    "personal-finance"

  ],

  "activationEvents": [
    "onStartupFinished"
  ],

  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      { "command": "financialAdvisor.openDashboard", "title": "Open Financial Dashboard", "category": "Financial Advisor" },
      { "command": "financialAdvisor.addTransaction", "title": "Add Transaction", "category": "Financial Advisor" },
      { "command": "financialAdvisor.addAccount", "title": "Add Account", "category": "Financial Advisor" },
      { "command": "financialAdvisor.analyzeSpending", "title": "Analyze Spending", "category": "Financial Advisor" },
      { "command": "financialAdvisor.setupMCP", "title": "Setup MCP Server", "category": "Financial Advisor" },
      { "command": "financialAdvisor.generateReport", "title": "Generate Financial Report", "category": "Financial Advisor" },
      { "command": "financialAdvisor.configureAI", "title": "Configure AI Provider", "category": "Financial Advisor" }
    ]
  },

  "scripts": {

    "vscode:prepublish": "npm run compile",

    "compile": "tsc -p ./",

    "compile:test": "tsc -p ./tsconfig.test.json",

    "watch": "tsc -watch -p ./",

    "pretest": "npm run compile:test && npm run lint",

    "lint": "eslint src --ext ts",

    "lint:fix": "eslint src --ext ts --fix",

    "format": "prettier --write \"src/**/*.ts\"",

    "format:check": "prettier --check \"src/**/*.ts\"",

    "test": "node ./out/test/runTest.js",

    "test:unit": "npm run compile:test && mocha out/test/unit/**/*.test.js",

    "test:integration": "npm run compile:test && mocha out/test/integration/**/*.test.js",

    "coverage": "nyc --require ts-node/register --extension .ts mocha test/unit/**/*.test.ts",
    "build": "npm run compile",
    "build:all:win": "pwsh -File scripts/build.ps1",
    "build:all": "bash ./scripts/build.sh",

    "package": "vsce package",

    "publish": "vsce publish",

  "clean": "rimraf out *.vsix",

    "setup": "npm install && npm run setup:hooks",

    "setup:hooks": "npx husky install && npx husky add .husky/pre-commit 'npx lint-staged'",

    "bootstrap": "npm run setup && npm run build && npm run test:unit",

    "audit:security": "npm audit && npx osv-scanner -r .",

    "check:all": "npm run lint && npm run format:check && npm run build && npm run test:unit",

    "sbom:generate": "npx @cyclonedx/cdxgen -o sbom.json --type npm .",

    "licenses:check": "npx license-checker --summary",

    "licenses:report": "npx license-checker --json > licenses.json && npx license-checker --csv > licenses.csv"

  },

  "devDependencies": {

    "@cyclonedx/cdxgen": "^11.7.0",

    "@istanbuljs/nyc-config-typescript": "^1.0.2",

    "@types/glob": "^9.0.0",

    "@types/mocha": "^10.0.10",

    "@types/node": "^24.5.2",

    "@types/vscode": "^1.104.0",

    "@typescript-eslint/eslint-plugin": "^8.44.0",

    "@typescript-eslint/parser": "^8.44.0",

    "@vscode/test-electron": "^2.5.2",

    "@vscode/vsce": "^3.6.0",

    "eslint": "^9.36.0",

    "glob": "^11.0.3",

    "husky": "^9.1.7",

    "license-checker": "^25.0.1",

    "lint-staged": "^16.1.6",

    "mocha": "^11.7.2",

    "nyc": "^17.1.0",

    "prettier": "^3.6.2",

    "rimraf": "^6.0.1",

    "ts-node": "^10.9.2",

    "typescript": "^5.9.2"

  },

  "dependencies": {

    "@modelcontextprotocol/sdk": "^1.18.1"

  },

  "repository": {

    "type": "git",

    "url": "https://github.com/plures/FinancialAdvisor.git"

  },

  "lint-staged": {

    "*.{ts,js}": [

      "eslint --fix",

      "prettier --write"

    ],

    "*.{json,md,yml,yaml}": [

      "prettier --write"

    ]

  },

  "license": "MIT",

  "homepage": "https://github.com/plures/FinancialAdvisor#readme",

  "bugs": {

    "url": "https://github.com/plures/FinancialAdvisor/issues"

  }

}

