{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2020"],
    "sourceMap": true,
    // Disable verbatimModuleSyntax to allow type-only imports without "type" keyword
    "verbatimModuleSyntax": false,
    // Enable emit since parent tsconfig may have noEmit for type-checking only
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../domain" },
    { "path": "../ai-integration" },
    { "path": "../analytics" }
  ]
}
